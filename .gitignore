__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env
.env.local
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
build/
dist/
data/kb/index/
*.sqlite
*.sqlite-journal
*.db
debrief_*.md
.DS_Store

# Node (vrai-faces has its own .gitignore too; this is a safety net)
node_modules/
*.log

# Avatar runtime assets — consented uploads (skins + assigned portraits).
# Never commit faces; keep the dir READMEs.
portal/data/face_skins/
portal/data/face_portraits/*.png
portal/data/face_portraits/*.jpg
portal/data/face_portraits/*.jpeg
portal/data/face_portraits/*.webp

# FR-013 — per-install local-context library (authored standing orders /
# formulary / priorities). Program data, not repo content.
portal/data/local_context/

# FR-013b — instructor-authored scenarios + the personas they mint. Program
# data (per-install), not repo content.
portal/data/authored/

# FR-014 — student-scanned chart documents (per-run training artifacts; cleared on reset).
portal/data/scanned_documents/

# FR-018 S4 — instructor-authored scenario support documents (persistent, NOT
# reset-cleared; shared via FR-017 export rather than committed binaries).
portal/data/scenario_docs/

# Never commit dev TLS material (private keys + local CA). Regenerate per machine
# with scripts/make-dev-cert.sh.
portal/data/certs/

# Runtime device/encounter state — never commit (per-deployment, regenerated).
portal/data/face_portraits/*.skin
data/debriefs/

# Per-deployment device-token secret (ADR-0027) — never commit.
portal/data/.face_token_secret
