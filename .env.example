# Required — Anthropic API for Haiku 4.5, Sonnet 4.6, Opus 4.6 calls
ANTHROPIC_API_KEY=

# Required for B3 (KB vector index). Choose ONE embedding provider:
VOYAGE_API_KEY=
# OPENAI_API_KEY=

# Telemetry store — defaults to local SQLite
DATABASE_URL=sqlite:///data/telemetry.db

# Portal bind port (default 8760; the tablet-onboarding helper uses PORT+1 = 8761).
# Moved off 8765 to avoid clashing with another local project on that port.
MEDSIM_PORT=8760

# Optional — instructor dashboard bind address
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8762
