{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ChartSeed",
  "description": "MEDSIM V3 — neutral, EHR-agnostic patient seed. Frozen at session start so the comparison engine can diff student-written documentation against the pre-populated baseline.",
  "type": "object",
  "required": ["mrn", "name", "dob", "code_status", "safety_class"],
  "properties": {
    "mrn":           {"type": "string", "minLength": 4},
    "fin":           {"type": ["string", "null"]},
    "name":          {"type": "string"},
    "dob":           {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "sex":           {"type": "string", "enum": ["F", "M", "U"]},
    "pronouns":      {"type": "string"},
    "code_status":   {"type": "string", "enum": ["Full Code", "DNR", "DNR/DNI"]},
    "allergies":     {"type": "array", "items": {"type": "object",
                       "properties": {"substance": {"type": "string"}, "reaction": {"type": "string"}, "severity": {"type": "string"}}}},
    "problem_list":  {"type": "array", "items": {"type": "object",
                       "properties": {"name": {"type": "string"}, "icd": {"type": "string"}, "onset": {"type": "string"}}}},
    "medications":   {"type": "array", "items": {"type": "object",
                       "properties": {"name": {"type": "string"}, "dose": {"type": "string"}, "frequency": {"type": "string"}}}},
    "immunizations": {"type": "array"},
    "social_history":{"type": "object"},
    "family_history":{"type": "array"},
    "surgical_history": {"type": "array"},
    "vitals_baseline":{"type": "array"},
    "labs_recent":   {"type": "array"},
    "notes_recent":  {"type": "array"},
    "care_team":     {"type": "array"},
    "encounter":     {"type": "object"},
    "altered_state": {"type": ["string", "null"]},
    "safety_class":  {"type": "string", "enum": ["baseline", "sensitive", "high-risk"]},
    "module_anchors":{"type": "array", "items": {"type": "string"}},
    "weight":        {"type": "string"},
    "height":        {"type": "string"},
    "bsa":           {"type": "string"},
    "insurance":     {"type": "string"}
  }
}
